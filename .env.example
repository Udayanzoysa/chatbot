# Server
PORT=3000
WEBHOOK_PATH=/webhook
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/chatbot

# Meta webhook verification (you choose this string; paste the same value in Meta console)
META_VERIFY_TOKEN=change-me-to-a-long-random-string

# Meta App Secret (App Dashboard → Settings → Basic)
META_APP_SECRET=

# Messenger + Instagram (Page access token — long-lived)
META_PAGE_ACCESS_TOKEN=

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: skip signature checks in local smoke tests only (never in production)
SKIP_META_SIGNATURE=false
