# Server
PORT=3000
WEBHOOK_PATH=/webhook
NODE_ENV=production

# --- Postgres (docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chatbot

# Used by the app container (host = postgres service name)
DOCKER_DATABASE_URL=postgresql://postgres:changeme@postgres:5432/chatbot

# Local npm only (host = localhost). Encode special chars: @ -> %40
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/chatbot

# Meta webhook verification (same string in Meta console)
META_VERIFY_TOKEN=change-me-to-a-long-random-string

# Meta App Secret (App Dashboard → Settings → Basic)
# Quote if it contains # * etc.
META_APP_SECRET=

# Messenger + Instagram (Page access token — long-lived)
META_PAGE_ACCESS_TOKEN=

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Never true on a public server
SKIP_META_SIGNATURE=false
