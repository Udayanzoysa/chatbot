{
  "name": "meta-gemini-sales-agent",
  "version": "1.0.0",
  "description": "24/7 Meta (WhatsApp, Messenger, Instagram) sales agent powered by Gemini + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "whatsapp",
    "messenger",
    "instagram",
    "gemini",
    "sales-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.4.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
